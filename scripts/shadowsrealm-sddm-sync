#!/usr/bin/env bash
# ShadowsRealm: regenerate the SDDM theme palette from the active Hyprland scheme.
#
# Reads ~/.config/hypr/scheme/current.conf (the live Material You palette that the
# Caelestia shell rewrites on every wallpaper/scheme change) and writes the
# theme's Colors.qml. The theme lives under /usr/share/sddm/themes (root-owned),
# so this script is installed root-owned and invoked via a narrowly-scoped
# NOPASSWD sudoers rule from a user systemd path unit.
#
# Usage: shadowsrealm-sddm-sync [SCHEME_CONF] [THEME_DIR]
set -euo pipefail

# When run via sudo from the user path unit, fall back to the invoking user's HOME.
USER_HOME="${SUDO_USER:+/home/$SUDO_USER}"
USER_HOME="${USER_HOME:-$HOME}"

SCHEME_CONF="${1:-$USER_HOME/.config/hypr/scheme/current.conf}"
THEME_DIR="${2:-/usr/share/sddm/themes/shadowsrealm}"
OUT="$THEME_DIR/Colors.qml"

if [[ ! -f "$SCHEME_CONF" ]]; then
    echo "shadowsrealm-sddm-sync: scheme file not found: $SCHEME_CONF" >&2
    exit 1
fi

# Pull a "$name = hex" value out of the Hyprland scheme file.
get() {
    local key="$1" default="$2" val
    val="$(sed -n "s/^\\\$${key}[[:space:]]*=[[:space:]]*\\([0-9a-fA-F]\\{6,8\\}\\).*/\\1/p" "$SCHEME_CONF" | head -n1)"
    if [[ -n "$val" ]]; then printf '#%s' "$val"; else printf '%s' "$default"; fi
}

bg=$(get background "#131317")
onBg=$(get onBackground "#e5e1e7")
surface=$(get surface "#131317")
surfaceContainer=$(get surfaceContainer "#201f23")
surfaceContainerHigh=$(get surfaceContainerHigh "#2a292e")
surfaceContainerHighest=$(get surfaceContainerHighest "#353438")
onSurface=$(get onSurface "#e5e1e7")
onSurfaceVariant=$(get onSurfaceVariant "#c8c5d1")
outline=$(get outline "#918f9a")
outlineVariant=$(get outlineVariant "#47464f")
primary=$(get primary "#c2c1ff")
onPrimary=$(get onPrimary "#2a2a60")
primaryContainer=$(get primaryContainer "#7171ac")
onPrimaryContainer=$(get onPrimaryContainer "#ffffff")
err=$(get error "#ffb4ab")
onErr=$(get onError "#690005")
shadow=$(get shadow "#000000")

mkdir -p "$THEME_DIR"
cat > "$OUT" <<EOF
pragma Singleton
import QtQuick

// ShadowsRealm SDDM palette. AUTO-GENERATED by shadowsrealm-sddm-sync.
QtObject {
    readonly property color background:            "${bg}"
    readonly property color onBackground:          "${onBg}"
    readonly property color surface:               "${surface}"
    readonly property color surfaceContainer:      "${surfaceContainer}"
    readonly property color surfaceContainerHigh:  "${surfaceContainerHigh}"
    readonly property color surfaceContainerHighest:"${surfaceContainerHighest}"
    readonly property color onSurface:             "${onSurface}"
    readonly property color onSurfaceVariant:      "${onSurfaceVariant}"
    readonly property color outline:               "${outline}"
    readonly property color outlineVariant:        "${outlineVariant}"
    readonly property color primary:               "${primary}"
    readonly property color onPrimary:             "${onPrimary}"
    readonly property color primaryContainer:      "${primaryContainer}"
    readonly property color onPrimaryContainer:    "${onPrimaryContainer}"
    readonly property color error:                 "${err}"
    readonly property color onError:               "${onErr}"
    readonly property color shadow:                "${shadow}"
}
EOF

echo "shadowsrealm-sddm-sync: wrote $OUT"
